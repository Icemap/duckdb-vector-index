---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InstallBar from '../components/InstallBar.tsx';

interface Props {
  title: string;
  tagline?: string;
}
const { title, tagline } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={tagline ?? 'DuckDB Vector Search Extension'} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header tagline={tagline}>
      <InstallBar slot="install" client:load />
    </Header>

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
