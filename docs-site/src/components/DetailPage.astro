---
import type { VindexNode } from '../data/nodes';

interface Props {
  node: VindexNode;
}
const { node } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="max-w-5xl mx-auto" style="padding: 48px 32px;">
  <a
    href={`${base}/`}
    class="inline-block font-mono uppercase mb-6"
    style="font-size: 11px; letter-spacing: 0.15em; color: var(--text-dim);"
    onmouseover="this.style.color='var(--accent-blue)'"
    onmouseout="this.style.color='var(--text-dim)'"
  >
    ← Back to overview
  </a>

  <div
    class="font-mono uppercase mb-2"
    style="font-size: 11px; letter-spacing: 0.18em; color: var(--text-dim);"
  >
    {node.kind === 'algorithm' ? 'Algorithm' : 'Quantizer'}
  </div>
  <h1
    class="font-semibold tracking-tight mb-3"
    style="font-size: 36px; color: var(--accent-blue);"
  >
    {node.label}
  </h1>
  <p class="max-w-3xl leading-relaxed mb-10" style="font-size: 15px; color: var(--text-main);">
    {node.blurb}
  </p>

  {node.paperUrl && (
    <section
      class="mb-10"
      style="border-left: 4px solid var(--accent-blue); background: rgba(41, 197, 255, 0.06); padding: 20px 24px;"
    >
      <div
        class="font-mono uppercase mb-2"
        style="font-size: 11px; letter-spacing: 0.18em; color: var(--accent-blue);"
      >
        Reference Paper — Credits
      </div>
      <h2 class="font-semibold leading-snug mb-2" style="font-size: 18px; color: #fff;">
        <a
          href={node.paperUrl}
          target="_blank"
          rel="noreferrer noopener"
          style="color: inherit; text-decoration: none;"
          onmouseover="this.style.textDecoration='underline'"
          onmouseout="this.style.textDecoration='none'"
        >
          {node.paperTitle}
        </a>
      </h2>
      <p class="mb-1" style="font-size: 13px; color: var(--text-main);">{node.paperAuthors}</p>
      <p class="font-mono uppercase mb-3" style="font-size: 11px; letter-spacing: 0.1em; color: var(--text-dim);">
        {node.paperVenue}
      </p>
      <p class="leading-relaxed mb-3" style="font-size: 13px; color: var(--text-dim);">
        {node.paperSummary}
      </p>
      <a
        href={node.paperUrl}
        target="_blank"
        rel="noreferrer noopener"
        class="inline-block font-mono uppercase"
        style="font-size: 11px; letter-spacing: 0.12em; color: var(--accent-blue);"
        onmouseover="this.style.color='var(--accent-green)'"
        onmouseout="this.style.color='var(--accent-blue)'"
      >
        Read paper at official venue →
      </a>
    </section>
  )}

  <slot />
</article>
