---
import { GITHUB_REPO_URL, RELEASE_VERSION } from '../data/release';

interface Props {
  tagline?: string;
}
const {
  tagline = 'High-performance vector similarity search natively integrated into DuckDB. Supporting HNSW, IVF, DiskANN, and SPANN with advanced quantization layers.',
} = Astro.props;
---

<!-- Top bar: 120×120 blue identity tile + hero text + GitHub button on the right.
     Matches ref/design/…html exactly; height is fixed so we can size the
     below-the-fold marker. -->
<header class="flex items-stretch border-b border-line" style="height:120px;">
  <a
    href={import.meta.env.BASE_URL}
    aria-label="vindex home"
    class="flex items-center justify-center font-sans font-extrabold flex-shrink-0"
    style="background-color: var(--accent-blue); color: var(--text-on-accent); width:120px; font-size:32px; letter-spacing:-1px;"
  >
    vindex
  </a>

  <div class="flex-grow flex flex-col justify-center px-[30px] py-5 min-w-0">
    <h1 class="font-semibold text-white mb-1" style="font-size:18px;">
      DuckDB Vector Search Extension
    </h1>
    <p class="max-w-[720px] text-fg-dim leading-snug truncate-lines">
      {tagline}
    </p>
  </div>

  <div class="flex items-center pr-[30px]">
    <a
      href={GITHUB_REPO_URL}
      target="_blank"
      rel="noreferrer noopener"
      class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-wider px-3 py-2 border transition"
      style="border-color: var(--border-color); color: var(--text-main);"
      onmouseover="this.style.borderColor='var(--accent-blue)'; this.style.color='var(--accent-blue)'"
      onmouseout="this.style.borderColor='var(--border-color)'; this.style.color='var(--text-main)'"
    >
      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden>
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
      GitHub
    </a>
  </div>
</header>

<!-- Install strip: label + yellow command boxes + version. The InstallBar
     react island fills the central slot so the command strings stay in sync
     with the selected platform. -->
<div
  class="flex items-center gap-5 border-b border-line"
  style="background-color: var(--strip); padding: 12px 30px;"
>
  <slot name="install" />
  <span class="flex-grow"></span>
  <div class="font-mono uppercase tracking-wider text-fg-dim" style="font-size:10px; font-weight:700;">
    Version {RELEASE_VERSION}
  </div>
</div>
