---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/DetailPage.astro';
import { findNode } from '../../data/nodes';
const node = findNode('ivf')!;
---

<BaseLayout title={`${node.label} — DuckDB Vector Index`} tagline={node.blurb}>
  <DetailPage node={node}>
    <h2 class="text-xl font-semibold text-gray-100 mb-4">At a glance</h2>
    <p class="text-sm text-gray-300 leading-relaxed mb-6">
      Inverted File index partitions the vector space with k-means into <code class="font-mono text-teal-soft">nlist</code>
      Voronoi cells. Each vector is assigned to its closest centroid and stored in that cell's
      posting list. At query time we probe the <code class="font-mono text-teal-soft">nprobe</code>
      closest centroids and scan their posting lists. Build is cheap, recall/speed is tunable
      with a single knob, and any of the quantizers plug in orthogonally (IVF-Flat / IVF-RaBitQ /
      IVF-PQ / IVF-ScaNN).
    </p>

    <h2 class="text-xl font-semibold text-gray-100 mb-4">Parameters</h2>
    <div class="overflow-x-auto mb-8">
      <table class="w-full text-sm border border-ink-600">
        <thead class="bg-ink-800 text-gray-400 font-mono text-xs uppercase tracking-wider">
          <tr><th class="text-left px-4 py-2">Option</th><th class="text-left px-4 py-2">Default</th><th class="text-left px-4 py-2">Notes</th></tr>
        </thead>
        <tbody class="text-gray-300">
          <tr class="border-t border-ink-700"><td class="px-4 py-2 font-mono">nlist</td><td class="px-4 py-2 font-mono">1024</td><td class="px-4 py-2">Number of Voronoi cells. Rule of thumb: √N for small datasets, 4√N at scale.</td></tr>
          <tr class="border-t border-ink-700"><td class="px-4 py-2 font-mono">nprobe</td><td class="px-4 py-2 font-mono">32</td><td class="px-4 py-2">Cells visited per query. Higher recall ↔ higher latency.</td></tr>
          <tr class="border-t border-ink-700"><td class="px-4 py-2 font-mono">quantizer</td><td class="px-4 py-2 font-mono">'flat'</td><td class="px-4 py-2">flat / rabitq / pq / scann all supported.</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="text-xl font-semibold text-gray-100 mb-4">Example</h2>
<pre class="bg-ink-800 border border-ink-700 p-4 font-mono text-xs overflow-x-auto"><code>CREATE INDEX docs_idx ON docs USING IVF (embedding)
    WITH (metric='cosine', quantizer='rabitq', bits=3, rerank=10,
          nlist=1024, nprobe=32);</code></pre>
  </DetailPage>
</BaseLayout>
