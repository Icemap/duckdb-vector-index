# name: test/sql/hnsw/hnsw_pq.test
# group: [hnsw]
#
# HNSW + classical Product-Quantization wiring. Uses default PQ params
# (m = dim/4, bits = 8) because the HNSW option 'm' is already taken (graph
# degree) — PQ-specific overrides have to be supplied through the quantizer
# options that don't collide, or left as defaults.

require vindex

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t1 (vec FLOAT[8]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c,d,a+b,b+c,c+d,a+d)
FROM range(1,6) ra(a), range(1,6) rb(b), range(1,6) rc(c), range(1,6) rd(d);

statement ok
CREATE INDEX my_idx ON t1 USING HNSW (vec)
    WITH (quantizer='pq', bits=8, rerank=10);

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3,4,3,5,7,5]::FLOAT[8]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3,4,3,5,7,5]::FLOAT[8]) LIMIT 3);
----
3
