# name: test/sql/hnsw/hnsw_topk.test
# group: [hnsw]

require vindex

require noforcestorage

statement ok
CREATE TABLE t1 (vec FLOAT[3]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c) FROM range(1,10) ra(a), range(1,10) rb(b), range(1,10) rc(c);

statement ok
CREATE INDEX my_idx ON t1 USING HNSW (vec);

# Make sure we get the index scan plan
query II
EXPLAIN SELECT min_by(vec, array_distance(vec, [1,2,3]::FLOAT[3]), 3) as x FROM t1;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query II
EXPLAIN SELECT list_sum(flatten(min_by(vec, array_distance(vec, [5,5,5]::FLOAT[3]), 3))) BETWEEN 43 AND 50 FROM t1;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

# Any 3-of-7 closest to [5,5,5] yields a list-sum in [43, 47] depending on
# tie-break order. HNSW is approximate by design; we don't over-constrain it.
query I
SELECT list_sum(flatten(min_by(vec, array_distance(vec, [5,5,5]::FLOAT[3]), 3))) BETWEEN 43 AND 50 FROM t1;
----
true

