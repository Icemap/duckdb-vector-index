# name: test/sql/spann/spann_pragma.test
# group: [spann]
#
# Session-level vindex_nprobe override + pragma_vindex_spann_index_info().

require vindex

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t1 (vec FLOAT[3]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c) FROM range(1,10) ra(a), range(1,10) rb(b), range(1,10) rc(c);

statement ok
CREATE INDEX my_idx ON t1 USING SPANN (vec) WITH (nlist=8, nprobe=1, replica_count=4, closure_factor=1.5);

# Boost nprobe at query time; should still route through the index.
statement ok
SET vindex_nprobe = 8;

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT array_distance([1,2,3]::FLOAT[3], vec) < 1.5 FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
true
true
true

# pragma surfaces SPANN-specific columns.
query I
SELECT count(*) FROM pragma_vindex_spann_index_info() WHERE index_name = 'my_idx';
----
1

query I
SELECT nlist FROM pragma_vindex_spann_index_info() WHERE index_name = 'my_idx';
----
8

query I
SELECT replica_count FROM pragma_vindex_spann_index_info() WHERE index_name = 'my_idx';
----
4

# entries ≥ count (replicas inflate entries, not unique rows).
query I
SELECT entries >= count FROM pragma_vindex_spann_index_info() WHERE index_name = 'my_idx';
----
true
