# name: test/sql/spann/spann_persist.test
# group: [spann]
#
# SPANN persistence: create, checkpoint, reopen. Exercises
# SpannIndex::SerializeToDisk / ReadStateStream end-to-end.

require vindex

load __TEST_DIR__/temp_index_spann_storage.db

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t1 (vec FLOAT[3]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c) FROM range(1,10) ra(a), range(1,10) rb(b), range(1,10) rc(c);

statement ok
CREATE INDEX my_idx ON t1 USING SPANN (vec) WITH (nlist=8, replica_count=4, closure_factor=1.5);

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT array_distance([1,2,3]::FLOAT[3], vec) < 1.5 FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
true
true
true

statement ok
CHECKPOINT;

restart

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT array_distance([1,2,3]::FLOAT[3], vec) < 1.5 FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
true
true
true
