# name: test/sql/diskann/diskann_scann.test
# group: [diskann]
#
# DiskANN + ScaNN anisotropic PQ. Same layout as PQ plus the eta knob
# (h_parallel / h_perpendicular). This test exercises the train → build →
# scan → rerank wiring; recall-quality evaluation belongs in the benchmark
# harness.

require vindex

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t1 (vec FLOAT[8]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c,d,a+b,b+c,c+d,a+d)
FROM range(1,6) ra(a), range(1,6) rb(b), range(1,6) rc(c), range(1,6) rd(d);

statement ok
CREATE INDEX scann_idx ON t1 USING DISKANN (vec)
    WITH (quantizer='scann', m=4, bits=8, eta=4.0, rerank=10);

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3,4,3,5,7,5]::FLOAT[8]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3,4,3,5,7,5]::FLOAT[8]) LIMIT 3);
----
3
