# name: test/sql/diskann/diskann_persist.test
# group: [diskann]
#
# DiskANN persistence: create, checkpoint, reopen. Exercises
# DiskAnnIndex::SerializeToDisk / ReadStateStream end-to-end, including the
# out-of-band codes_ array and the node-block allocator.

require vindex

load {TEST_DIR}/temp_index_diskann_storage.db

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t1 (vec FLOAT[3]);

statement ok
INSERT INTO t1 SELECT array_value(a,b,c) FROM range(1,10) ra(a), range(1,10) rb(b), range(1,10) rc(c);

statement ok
CREATE INDEX my_idx ON t1 USING DISKANN (vec)
    WITH (quantizer='rabitq', bits=3, rerank=10);

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT array_distance([1,2,3]::FLOAT[3], vec) < 1.5 FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
true
true
true

statement ok
CHECKPOINT;

# Skipped on upstream DuckDB v1.5.2: IndexCatalogEntry::GetInfo() drops the
# WITH options when rebuilding CreateInfo, so after `restart` the DiskANN
# index reloads with default options (FLAT quantizer) and the binder rejects
# it. Fixed upstream by:
#   https://github.com/duckdb/duckdb/issues/22316
#   https://github.com/duckdb/duckdb/pull/22317 (merged to main, not yet in
#   a v1.5.x release)
# Re-enable this section once a DuckDB patch release ships with the fix.
mode skip

restart

query II
EXPLAIN SELECT * FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
physical_plan	<REGEX>:.*VINDEX_INDEX_SCAN.*

query I
SELECT array_distance([1,2,3]::FLOAT[3], vec) < 1.5 FROM t1 ORDER BY array_distance(vec, [1,2,3]::FLOAT[3]) LIMIT 3;
----
true
true
true

mode unskip
