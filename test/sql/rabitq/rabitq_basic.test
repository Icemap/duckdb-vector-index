# name: test/sql/rabitq/rabitq_basic.test
# group: [rabitq]
#
# RaBitQ quantizer + HNSW end-to-end SQL coverage.
#
# Exercises (per AGENTS.md §2.1 step 4):
#   - CREATE INDEX ... USING HNSW (vec) WITH (quantizer='rabitq', bits=N)
#   - Supported bit-widths + bits=6 rejection
#   - Plan shape: EXPLAIN goes through HNSW_INDEX_SCAN
#   - End-to-end correctness at bits=3 (>=99% Recall@10 target per README)
#   - rerank compensates for bits=1 coarse-filter noise
#
# Numeric recall on large fixtures lives in test/bench/; this file keeps
# deterministic, small cases so it runs on every push.

require vindex

require noforcestorage

# --- bits validation ---------------------------------------------------------

statement ok
CREATE TABLE t (vec FLOAT[16]);

statement error
CREATE INDEX bad ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=6);
----
vindex: rabitq bits=6 is not supported

statement error
CREATE INDEX bad ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=0);
----
vindex: rabitq bits=0 is not supported

statement error
CREATE INDEX bad ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=9);
----
vindex: rabitq bits=9 is not supported

statement error
CREATE INDEX bad ON t USING HNSW (vec) WITH (quantizer='unknown_quant');
----
vindex: unknown quantizer

# --- every supported bit-width creates successfully --------------------------

statement ok
INSERT INTO t SELECT array_value(
    a, a*1.1, a*0.9, a*1.3, a*0.7, a*1.5, a*0.5, a*1.7,
    a*0.3, a*1.9, a*0.1, a*2.1, a*-0.1, a*2.3, a*-0.3, a*2.5
)::FLOAT[16] FROM range(1, 200) r(a);

statement ok
CREATE INDEX idx_b1 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=1, rerank=20);

statement ok
DROP INDEX idx_b1;

statement ok
CREATE INDEX idx_b2 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=2, rerank=10);

statement ok
DROP INDEX idx_b2;

statement ok
CREATE INDEX idx_b3 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=3);

statement ok
DROP INDEX idx_b3;

statement ok
CREATE INDEX idx_b4 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=4);

statement ok
DROP INDEX idx_b4;

statement ok
CREATE INDEX idx_b5 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=5);

statement ok
DROP INDEX idx_b5;

statement ok
CREATE INDEX idx_b7 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=7);

statement ok
DROP INDEX idx_b7;

statement ok
CREATE INDEX idx_b8 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=8);

statement ok
DROP INDEX idx_b8;

# --- plan: optimizer picks the HNSW index scan over RaBitQ-encoded data ------

statement ok
CREATE INDEX idx_b3 ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=3, rerank=10);

query II
EXPLAIN SELECT vec FROM t ORDER BY array_distance(vec, [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16]) LIMIT 5;
----
physical_plan	<REGEX>:(?s).*TOP_N.*HNSW_INDEX_SCAN.*

# --- correctness: bits=3 retrieves the exact match as top-1 ------------------
# The first vector in the table is [1, 1.1, 0.9, ...] and is inserted as-is.
# bits=3 + exact-distance TopN rerank should always have it at position 1.

query I
SELECT vec = [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16]
FROM t ORDER BY array_distance(vec, [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16])
LIMIT 1;
----
true

statement ok
DROP INDEX idx_b3;

# --- bits=1 WITHOUT rerank: coarse filter, may miss exact top-1 --------------
# We don't assert that it fails (synthetic fixture is small enough it often
# still gets lucky), just that it runs end-to-end.

statement ok
CREATE INDEX idx_b1_norerank ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=1, rerank=1);

statement ok
SELECT vec FROM t ORDER BY array_distance(vec, [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16]) LIMIT 5;

statement ok
DROP INDEX idx_b1_norerank;

# --- bits=1 + rerank=20 recovers the exact match -----------------------------
# This is the bits=1 + rerank pairing documented in README §"Quantizer bits vs
# recall". The rerank pass re-scores with exact distance from the column.

statement ok
CREATE INDEX idx_b1_rerank ON t USING HNSW (vec) WITH (quantizer='rabitq', bits=1, rerank=20);

query I
SELECT vec = [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16]
FROM t ORDER BY array_distance(vec, [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16])
LIMIT 1;
----
true

# --- session override of rerank ---------------------------------------------

statement ok
SET vindex_rerank_multiple = 40;

query I
SELECT vec = [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16]
FROM t ORDER BY array_distance(vec, [1.0, 1.1, 0.9, 1.3, 0.7, 1.5, 0.5, 1.7, 0.3, 1.9, 0.1, 2.1, -0.1, 2.3, -0.3, 2.5]::FLOAT[16])
LIMIT 1;
----
true

statement ok
RESET vindex_rerank_multiple;
